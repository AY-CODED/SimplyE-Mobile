{
  "version": 2,
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|Logo\\.png|BYD_HAN\\.jpg|modal\\.jpeg|assets/).*)",
      "destination": "/index.html"
    }
  ]
}